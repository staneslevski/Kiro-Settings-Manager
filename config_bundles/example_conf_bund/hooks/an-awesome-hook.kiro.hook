{
  "version": "1.0.0",
  "enabled": true,
  "name": "Commit after task",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "In the spec driven workflow only, you should prepare a commit and commit your code. Git commit is not a trusted command so you will need to ask the user for permission. You should do this as a last step after all other work is complete. "
  }
}